{
  "multipart": [
    {
      "apply": {"model": "buildcrafttransport:block/pipe_center"}
    },
    {
      "when": {"down": "true"},
      "apply": {"model": "buildcrafttransport:block/pipe_arm_down"}
    },
    {
      "when": {"up": "true"},
      "apply": {"model": "buildcrafttransport:block/pipe_arm_up"}
    },
    {
      "when": {"north": "true"},
      "apply": {"model": "buildcrafttransport:block/pipe_arm_north"}
    },
    {
      "when": {"south": "true"},
      "apply": {"model": "buildcrafttransport:block/pipe_arm_south"}
    },
    {
      "when": {"west": "true"},
      "apply": {"model": "buildcrafttransport:block/pipe_arm_west"}
    },
    {
      "when": {"east": "true"},
      "apply": {"model": "buildcrafttransport:block/pipe_arm_east"}
    }
  ]
}
